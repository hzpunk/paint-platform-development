generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("user")
  password  String?
  phone     String?
  bonusBalance Int    @default(0)
  totalSpent    Int    @default(0)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  lastLoginAt DateTime?
  lastLoginIp String?
  favorites Favorite[]
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  birthday  String?
  referralCode String? @unique
  referredById String?
  referredBy   User?   @relation("Referral", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referral")
  referralCount Int    @default(0)
  referralBonus Int    @default(0)
}

model Order {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  date      DateTime   @default(now())
  total     Float
  commission Float?  @default(0)
  status    String
  items     OrderItem[]
  bonusEarned Int?
  tracking    String?
  customerId String?
  customerName String?
  customerEmail String?
  customerPhone String?
  deliveryMethod String?
  deliveryAddress String?
  paymentMethod String?
  promoCode String?
  cancellationReason String?
  managerId String?
}

model OrderItem {
  id      String  @id @default(uuid())
  order   Order   @relation(fields: [orderId], references: [id])
  orderId String
  name    String
  volume  Float
  price   Float
  qty     Int
  productId String?
  color String?
  ral String?
}

model AuditEntry {
  id        String   @id @default(uuid())
  orderId   String
  actor     String
  from      String
  to        String
  at        DateTime @default(now())
}

model Favorite {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  productId String
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  rating    Int
  text      String?
  createdAt DateTime @default(now())
}

model Product {
  id              String       @id @default(uuid())
  name            String
  slug            String       @unique
  description     String?
  price           Float
  commission      Float?       @default(0)
  oldPrice        Float?
  stock           Int
  images          String[]
  categoryId      String
  category        Category     @relation(fields: [categoryId], references: [id])
  brandId         String
  brand           Brand        @relation(fields: [brandId], references: [id])
  type            String?
  surfaces        String[]
  badges          String[]
  rating          Float        @default(0)
  reviewsCount    Int          @default(0)
  colorable       Boolean      @default(false)
  shortSpec       String?
  specs           Json? // Keep as Json, ensure seed.ts handles it
  application     String?
  packaging       Json? // Keep as Json, ensure seed.ts handles it
  colors          Json? // Keep as Json, ensure seed.ts handles it
  reviews         Review[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Category {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  icon        String?
  description String?
  products    Product[]
}

model Brand {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Attribute {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  values    AttributeValue[]
}

model AttributeValue {
  id        String    @id @default(uuid())
  value     String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  attributeId String
}

model ColorMixingOrder {
  id        String    @id @default(uuid())
  baseProductId String
  targetColor String
  ral         String?
  status      String
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LoyaltyLevel {
  id              String    @id @default(uuid())
  name            String
  threshold       Int
  bonusPercentage Float
}

model Referral {
  id              String    @id @default(uuid())
  referrerId      String
  referredId      String
  bonusAmount     Int
  createdAt       DateTime  @default(now())
}

model WholesaleRequest {
  id          String    @id @default(uuid())
  companyName String
  tin         String
  contactName String
  phone       String
  email       String
  status      String
  createdAt   DateTime  @default(now())
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  authorId    String
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  imageUrl    String
  linkUrl     String
  isActive    Boolean   @default(false)
}

model StaticPage {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  updatedAt   DateTime  @updatedAt
}

model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountType    String
  discountValue   Float
  expiresAt       DateTime?
  usageLimit      Int?
  usageCount      Int       @default(0)
  isActive        Boolean   @default(true)
}

model Setting {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String?
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  title     String
  type      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketingMetric {
  id            String   @id @default(uuid())
  platform      String
  views         Int      @default(0)
  likes         Int      @default(0)
  followers     Int      @default(0)
  date          DateTime @default(now())
}

model FundAllocation {
  id          String   @id @default(uuid())
  name        String
  percentage  Float
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
